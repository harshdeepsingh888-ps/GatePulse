POSTGRES_DB=gatepulse_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_secure_password

DATABASE_URL=postgresql://postgres:replace_with_secure_password@postgres:5432/gatepulse_db?schema=public

LOG_LEVEL=info

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1h

ADMIN_SEED_NAME=GatePulse Admin
ADMIN_SEED_EMAIL=admin@gatepulse.local
ADMIN_SEED_PASSWORD=replace_with_secure_admin_password